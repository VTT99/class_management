# Copy to .env and fill in real values.

# Path to the DuckDB database file, relative to repo root.
DUCKDB_FILE=data/tutorial_center.duckdb

# Path to the Google service-account JSON key, relative to repo root.
GOOGLE_SERVICE_ACCOUNT_FILE=secrets/service_account.json

# Google Calendar ID to write lesson events to.
# (The calendar must be shared with the service account email as an editor.)
GOOGLE_CALENDAR_ID=

# Google Sheets spreadsheet ID used by scripts/download_sheet_to_db.py
# and scripts/seed_test_data.py.
GOOGLE_SHEETS_SPREADSHEET_ID=

# IANA timezone used when writing calendar events.
TIMEZONE=Asia/Hong_Kong

# Logging level: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# Optional bearer token. If set, all /api/* endpoints require
# `Authorization: Bearer <token>`. Leave empty to disable auth.
API_BEARER_TOKEN=

# Sub-path under which the app is served. Empty for "/", or e.g.
# "/class_management" when behind a reverse proxy that forwards
# https://example.com/class_management/* to this process.
# No trailing slash.
ROOT_PATH=

# When true, the FastAPI process also serves the HTML + /static assets at "/"
# (the usual integrated layout). Set to false for the "split" deploy where
# the frontend lives on a separate static host (e.g. Apache public_html) and
# this process is API-only.
SERVE_FRONTEND=true

# Comma-separated list of origins allowed to call this API via CORS.
# For the integrated/cPanel layouts the defaults are fine.
# For split-deploy, set this to the static frontend's origin, e.g.
# ALLOWED_ORIGINS=https://your-domain.com
ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
